# ══════════════════════════════════════════════════════════════════════════════
# Hagatna Backend — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ══════════════════════════════════════════════════════════════════════════════

# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Docker Compose overrides this to use container hostname 'postgres'
DATABASE_URL="postgresql://hagatna:CHANGE_ME@postgres:5432/hagatna_db?schema=public"
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30

# ─── REDIS ────────────────────────────────────────────────────────────────────
# Docker Compose overrides REDIS_HOST to 'redis'
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_ANOTHER_STRONG_PASSWORD

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_64_byte_random_hex_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_64_byte_random_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── FRONTEND URLs (comma-separated, no trailing slash) ──────────────────────
# These are the Vercel deployment URLs where CORS requests originate from
FRONTEND_URL="https://hagatna.vercel.app,https://admin-hagatna.vercel.app,https://vendor-hagatna.vercel.app"

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://api.hagatna.com/api/v1/auth/google/callback

# ─── FACEBOOK OAUTH ───────────────────────────────────────────────────────────
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=https://api.hagatna.com/api/v1/auth/facebook/callback

# ─── EMAIL / NODEMAILER ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
EMAIL_FROM="Hagatna <noreply@hagatna.com>"

# ─── UPLOADS ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
BACKEND_URL=http://localhost:5000

# ─── PAYMOB (Payment Gateway) ────────────────────────────────────────────────
# Leave all empty to disable Paymob (endpoints return 503)
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_HMAC_SECRET=
PAYMOB_IFRAME_ID=

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── SUPPORTED LOCALES ────────────────────────────────────────────────────────
SUPPORTED_LOCALES=en,ar
DEFAULT_LOCALE=ar
