// ─────────────────────────────────────────────────────────────────────────────
// Hagatna Multi-Vendor E-commerce — Prisma Schema
// PostgreSQL · 30 entities · Arabic/English (JSONB) · UUID PKs
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════
//  ENUMS
// ═══════════════════════════════════════════════════════

enum Role {
  admin
  vendor
  customer
}

enum Provider {
  local
  google
  facebook
}

enum VendorStatus {
  pending
  approved
  rejected
  suspended
}

enum ProductStatus {
  draft
  pending_approval
  active
  rejected
  archived
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum PaymentMethod {
  cod
  bank_transfer
  online
}

enum ShipmentStatus {
  preparing
  shipped
  in_transit
  out_for_delivery
  delivered
  failed
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum PromotionType {
  coupon
  flash_sale
  percentage_off
  bundle
}

enum DiscountType {
  percentage
  fixed
}

enum NotificationType {
  order
  payment
  review
  message
  promotion
  system
}

enum AttributeType {
  select        // single choice  — color: Red
  multi_select  // multiple       — features: [WiFi, Bluetooth]
  range         // numeric        — screen size, battery
  boolean       // yes / no       — waterproof
}

enum LoyaltyTransactionType {
  earned
  redeemed
  adjusted
  expired
}

// ═══════════════════════════════════════════════════════
//  USERS & AUTH
// ═══════════════════════════════════════════════════════

model User {
  id                 String    @id @default(uuid())
  name               String    @db.VarChar(100)
  email              String    @unique @db.VarChar(255)
  passwordHash       String?   @db.Text
  role               Role      @default(customer)
  phone              String?   @db.VarChar(20)
  avatar             String?   @db.Text
  isVerified         Boolean   @default(false)
  isActive           Boolean   @default(true)
  provider           Provider  @default(local)

  // OAuth
  googleId           String?   @unique @db.VarChar(255)
  facebookId         String?   @unique @db.VarChar(255)

  // Token storage (hashed)
  refreshToken       String?   @db.Text

  // OTP (stored in Redis, these are DB fallback)
  otpCode            String?   @db.VarChar(6)
  otpExpiresAt       DateTime?
  resetToken         String?   @db.VarChar(255)
  resetTokenExpires  DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  vendorProfile      VendorProfile?
  addresses          Address[]
  cart               Cart?
  orders             Order[]
  reviews            Review[]
  notifications      Notification[]
  wishlists          Wishlist[]
  couponUsages       CouponUsage[]
  customerConvs      Conversation[] @relation("CustomerConversations")
  messages           Message[]
  orderStatusHistory OrderStatusHistory[] @relation("ChangedBy")
  loyaltyAccount     LoyaltyAccount?
  mediaAssets        MediaAsset[]
  activityLogs       AdminActivityLog[]

  @@map("users")
}

// ═══════════════════════════════════════════════════════
//  VENDORS
// ═══════════════════════════════════════════════════════

model VendorPlan {
  id          String   @id @default(uuid())
  name        Json                          // LocalizedString
  description Json?                         // LocalizedString
  maxProducts Int?                          // null = unlimited
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories  VendorPlanCategory[]
  vendors     VendorProfile[]

  @@index([isActive])
  @@map("vendor_plans")
}

model VendorPlanCategory {
  planId     String
  categoryId String
  plan       VendorPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([planId, categoryId])
  @@map("vendor_plan_categories")
}

model VendorProfile {
  id               String       @id @default(uuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Plan
  planId           String?
  plan             VendorPlan?  @relation(fields: [planId], references: [id])

  // Commission (set per-vendor by admin, not inherited from plan)
  commissionRate   Decimal      @default(10.00) @db.Decimal(5, 2)

  // Multilingual fields (JSON: { en: "...", ar: "..." })
  storeName        Json                         // LocalizedString
  description      Json?                        // LocalizedString

  storeSlug                    String       @unique @db.VarChar(100)
  address                      String?      @db.Text
  city                         String?      @db.VarChar(100)
  country                      String?      @db.VarChar(100)
  phone                        String?      @db.VarChar(20)
  secondaryPhone               String?      @db.VarChar(20)
  taxCardNumber                String?      @unique @db.VarChar(50)
  commercialRegistrationNumber String?      @unique @db.VarChar(100)
  status                       VendorStatus @default(pending)
  rejectionReason  String?      @db.Text
  verifiedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  products         Product[]
  shipments        Shipment[]
  shippingMethods  ShippingMethod[]
  commissions      VendorCommission[]
  promotions       Promotion[]
  reviews          Review[]
  vendorConvs      Conversation[] @relation("VendorConversations")
  mediaAssets      MediaAsset[]

  @@index([status])
  @@index([planId])
  @@map("vendor_profiles")
}

// ═══════════════════════════════════════════════════════
//  CATEGORIES
// ═══════════════════════════════════════════════════════

model Category {
  id          String     @id @default(uuid())
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")

  // Multilingual
  name        Json                             // LocalizedString
  description Json?                            // LocalizedString

  slug        String     @unique @db.VarChar(100)
  image       String?    @db.Text
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  deletedAt   DateTime?                          // soft delete
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  products             Product[]
  attributeDefinitions AttributeDefinition[]
  vendorPlans          VendorPlanCategory[]
  loyaltyRedeemable    LoyaltyRedeemableCategory[]

  @@index([deletedAt])
  @@map("categories")
}

// ═══════════════════════════════════════════════════════
//  PRODUCTS
// ═══════════════════════════════════════════════════════

model Product {
  id                 String        @id @default(uuid())
  vendorId           String
  vendor             VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  categoryId         String
  category           Category      @relation(fields: [categoryId], references: [id])

  // Multilingual
  name               Json                          // LocalizedString
  description        Json?                         // LocalizedString

  slug               String        @unique @db.VarChar(255)
  price              Decimal       @db.Decimal(12, 2)
  comparePrice       Decimal?      @db.Decimal(12, 2)
  costPrice          Decimal?      @db.Decimal(12, 2)
  sku                String?       @unique @db.VarChar(100)
  stockQuantity      Int           @default(0)
  lowStockThreshold  Int           @default(5)
  status             ProductStatus @default(draft)
  isFeatured         Boolean       @default(false)
  viewsCount         Int           @default(0)
  approvalNote       String?       @db.Text       // admin rejection/approval note
  deletedAt          DateTime?                    // soft delete
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  variants           ProductVariant[]
  images             ProductImage[]
  tags               ProductTag[]
  attributes         ProductAttribute[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  reviews            Review[]
  wishlists          Wishlist[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
  @@index([deletedAt])
  @@map("products")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String   @db.VarChar(100)
  options       Json                              // e.g. { color: "red", size: "L" }
  price         Decimal  @db.Decimal(12, 2)
  comparePrice  Decimal? @db.Decimal(12, 2)
  sku           String?  @unique @db.VarChar(100)
  stockQuantity Int       @default(0)
  imageUrl      String?   @db.Text
  isActive      Boolean   @default(true)
  deletedAt     DateTime?                        // soft delete

  // Relations
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String  @db.Text
  altText   String? @db.VarChar(255)
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  @@index([productId])
  @@map("product_images")
}

model ProductTag {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       String  @db.VarChar(50)

  @@index([productId])
  @@index([tag])
  @@map("product_tags")
}

// ═══════════════════════════════════════════════════════
//  PRODUCT ATTRIBUTES (dynamic specs / filters)
// ═══════════════════════════════════════════════════════

/// Defines what filterable attributes a category supports.
/// e.g. "Mobiles" → [RAM, Storage, Screen Size, Color]
model AttributeDefinition {
  id           String        @id @default(uuid())
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  key          String        @db.VarChar(60)   // machine key: "ram", "screen_size"
  label        Json                             // { en: "RAM", ar: "الذاكرة" }
  type         AttributeType
  unit         String?       @db.VarChar(20)   // "GB", "inch", "mAh" — shown next to value
  options      Json?                            // string[] for select / multi_select
  isFilterable Boolean       @default(true)    // show in frontend filter panel?
  isRequired   Boolean       @default(false)   // vendor must fill before publish?
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  values       ProductAttribute[]

  @@unique([categoryId, key])
  @@index([categoryId, isFilterable])
  @@map("attribute_definitions")
}

/// Stores the actual value a specific product has for one attribute.
model ProductAttribute {
  id           String              @id @default(uuid())
  productId    String
  product      Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  definitionId String
  definition   AttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  value        String              @db.VarChar(255)  // "8GB" | "Black" | "true" | "6.1"

  @@unique([productId, definitionId])
  @@index([productId])
  @@index([definitionId, value])   // critical for facet queries
  @@map("product_attributes")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("wishlists")
}

// ═══════════════════════════════════════════════════════
//  ADDRESSES
// ═══════════════════════════════════════════════════════

model Address {
  id            String  @id @default(uuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String? @db.VarChar(50)            // e.g. "Home", "Work"
  recipientName String  @db.VarChar(100)
  phone         String  @db.VarChar(20)
  street        String  @db.Text
  city          String  @db.VarChar(100)
  country       String  @db.VarChar(100)
  zipCode       String?   @db.VarChar(20)
  isDefault     Boolean   @default(false)
  deletedAt     DateTime?                        // soft delete

  @@index([userId])
  @@map("addresses")
}

// ═══════════════════════════════════════════════════════
//  CART
// ═══════════════════════════════════════════════════════

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?    @db.VarChar(255)            // guest cart fallback
  updatedAt DateTime   @updatedAt

  // Relations
  items     CartItem[]

  @@map("carts")
}

model CartItem {
  id            String          @id @default(uuid())
  cartId        String
  cart          Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId     String
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  quantity      Int
  priceSnapshot Decimal         @db.Decimal(12, 2)  // price at time of adding

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

// ═══════════════════════════════════════════════════════
//  ORDERS
// ═══════════════════════════════════════════════════════

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  orderNumber     String      @unique @db.VarChar(20)
  status          OrderStatus @default(pending)
  subtotal        Decimal     @db.Decimal(12, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(12, 2)
  shippingFee     Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  shippingAddress Json                                    // snapshot at checkout
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(pending)
  notes                String?     @db.Text
  pointsRedeemed       Int         @default(0)
  pointsDiscount       Decimal     @default(0) @db.Decimal(12, 2)
  pointsEarned         Int         @default(0)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Relations
  items                OrderItem[]
  statusHistory        OrderStatusHistory[]
  payment              Payment?
  shipments            Shipment[]
  refunds              Refund[]
  commissions          VendorCommission[]
  couponUsages         CouponUsage[]
  reviews              Review[]
  conversations        Conversation[]
  loyaltyTransactions  LoyaltyTransaction[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String          @id @default(uuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  vendorId        String
  productSnapshot Json                                    // full product data at purchase time
  quantity        Int
  unitPrice       Decimal         @db.Decimal(12, 2)
  subtotal        Decimal         @db.Decimal(12, 2)
  status          OrderStatus     @default(pending)

  // Relations
  commissions     VendorCommission[]
  refunds         Refund[]

  @@index([orderId])
  @@index([vendorId])
  @@map("order_items")
}

model OrderStatusHistory {
  id             String      @id @default(uuid())
  orderId        String
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  previousStatus OrderStatus
  newStatus      OrderStatus
  note           String?     @db.Text
  changedById    String?
  changedBy      User?       @relation("ChangedBy", fields: [changedById], references: [id])
  createdAt      DateTime    @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

// ═══════════════════════════════════════════════════════
//  PAYMENTS
// ═══════════════════════════════════════════════════════

model Payment {
  id               String        @id @default(uuid())
  orderId          String        @unique
  order            Order         @relation(fields: [orderId], references: [id])
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("USD") @db.VarChar(3)
  method           PaymentMethod
  status           PaymentStatus @default(pending)
  transactionId    String?       @unique @db.VarChar(255)
  gatewayReference String?       @db.VarChar(255)
  gatewayResponse  Json?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  // Relations
  refunds          Refund[]

  @@map("payments")
}

model Refund {
  id          String        @id @default(uuid())
  paymentId   String
  payment     Payment       @relation(fields: [paymentId], references: [id])
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id])
  orderItemId String?
  orderItem   OrderItem?    @relation(fields: [orderItemId], references: [id])
  amount      Decimal       @db.Decimal(12, 2)
  reason      String?       @db.Text
  status      PaymentStatus @default(pending)
  processedAt DateTime?
  createdAt   DateTime      @default(now())

  @@index([orderId])
  @@map("refunds")
}

model VendorCommission {
  id              String        @id @default(uuid())
  vendorId        String
  vendor          VendorProfile @relation(fields: [vendorId], references: [id])
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  orderItemId     String
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])
  grossAmount     Decimal       @db.Decimal(12, 2)
  commissionRate  Decimal       @db.Decimal(5, 2)
  commissionAmount Decimal      @db.Decimal(12, 2)
  netAmount       Decimal       @db.Decimal(12, 2)
  status                 PaymentStatus @default(pending)
  paidAt                 DateTime?
  paymentProof           String?       @db.Text   // Cloudinary URL of payment receipt
  paymentProofPublicId   String?       @db.VarChar(255)
  createdAt              DateTime      @default(now())

  @@index([vendorId])
  @@index([orderId])
  @@map("vendor_commissions")
}

// ═══════════════════════════════════════════════════════
//  SHIPPING
// ═══════════════════════════════════════════════════════

model ShippingZone {
  id        String           @id @default(uuid())
  name      String           @db.VarChar(100)
  countries Json                                     // string[] of country codes
  regions   Json?                                    // string[] of region codes
  isActive  Boolean           @default(true)
  deletedAt DateTime?                            // soft delete
  createdAt DateTime          @default(now())

  // Relations
  methods   ShippingMethod[]

  @@map("shipping_zones")
}

model ShippingMethod {
  id               String        @id @default(uuid())
  zoneId           String
  zone             ShippingZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  vendorId         String?
  vendor           VendorProfile? @relation(fields: [vendorId], references: [id])

  // Multilingual
  name             Json                              // LocalizedString

  minDays          Int           @default(1)
  maxDays          Int           @default(7)
  price            Decimal       @db.Decimal(12, 2)
  isFree           Boolean       @default(false)
  minOrderForFree  Decimal?      @db.Decimal(12, 2)
  isActive         Boolean       @default(true)
  deletedAt        DateTime?                     // soft delete

  // Relations
  shipments        Shipment[]

  @@index([zoneId])
  @@map("shipping_methods")
}

model Shipment {
  id               String         @id @default(uuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id])
  vendorId         String
  vendor           VendorProfile  @relation(fields: [vendorId], references: [id])
  shippingMethodId String?
  shippingMethod   ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  carrier          String?        @db.VarChar(100)
  trackingNumber   String?        @db.VarChar(255)
  trackingUrl      String?        @db.Text
  status           ShipmentStatus @default(preparing)
  shippedAt        DateTime?
  estimatedDelivery DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([orderId])
  @@index([vendorId])
  @@map("shipments")
}

// ═══════════════════════════════════════════════════════
//  REVIEWS
// ═══════════════════════════════════════════════════════

model Review {
  id                 String       @id @default(uuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id])
  productId          String
  product            Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendorId           String
  vendor             VendorProfile @relation(fields: [vendorId], references: [id])
  orderId            String?
  order              Order?       @relation(fields: [orderId], references: [id])
  rating             Int                                      // 1-5
  title              String?      @db.VarChar(255)
  content            String?      @db.Text
  status             ReviewStatus @default(pending)
  isVerifiedPurchase Boolean      @default(false)
  helpfulCount       Int          @default(0)
  deletedAt          DateTime?                   // soft delete
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Relations
  media              ReviewMedia[]

  @@unique([userId, productId, orderId])
  @@index([productId])
  @@index([vendorId])
  @@index([status])
  @@map("reviews")
}

model ReviewMedia {
  id       String @id @default(uuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url      String @db.Text
  type     String @db.VarChar(10)                           // "image" | "video"

  @@index([reviewId])
  @@map("review_media")
}

// ═══════════════════════════════════════════════════════
//  PROMOTIONS & COUPONS
// ═══════════════════════════════════════════════════════

model Promotion {
  id                 String        @id @default(uuid())
  vendorId           String?
  vendor             VendorProfile? @relation(fields: [vendorId], references: [id])

  // Multilingual
  name               Json                               // LocalizedString

  type               PromotionType
  code               String?       @unique @db.VarChar(50)
  discountType       DiscountType
  discountValue      Decimal       @db.Decimal(10, 2)
  minPurchaseAmount  Decimal       @default(0) @db.Decimal(12, 2)
  maxDiscountAmount  Decimal?      @db.Decimal(12, 2)
  usageLimitTotal    Int?
  usageLimitPerUser  Int           @default(1)
  usageCount         Int           @default(0)
  startsAt           DateTime
  endsAt             DateTime?
  isActive           Boolean       @default(true)
  deletedAt          DateTime?                   // soft delete
  createdAt          DateTime      @default(now())

  // Relations
  usages             CouponUsage[]

  @@index([code])
  @@index([isActive])
  @@index([vendorId])
  @@map("promotions")
}

model CouponUsage {
  id              String    @id @default(uuid())
  promotionId     String
  promotion       Promotion @relation(fields: [promotionId], references: [id])
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id])
  discountApplied Decimal   @db.Decimal(12, 2)
  usedAt          DateTime  @default(now())

  @@unique([promotionId, userId, orderId])
  @@index([promotionId])
  @@index([userId])
  @@map("coupon_usages")
}

// ═══════════════════════════════════════════════════════
//  NOTIFICATIONS
// ═══════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  // Multilingual
  title     Json                                      // LocalizedString
  body      Json                                      // LocalizedString
  data      Json?                                     // extra context (orderId, productId, etc.)
  isRead    Boolean          @default(false)
  readAt    DateTime?
  deletedAt DateTime?                            // soft delete
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════
//  CHAT
// ═══════════════════════════════════════════════════════

model Conversation {
  id            String        @id @default(uuid())
  customerId    String
  customer      User          @relation("CustomerConversations", fields: [customerId], references: [id])
  vendorId      String
  vendor        VendorProfile @relation("VendorConversations", fields: [vendorId], references: [id])
  orderId       String?
  order         Order?        @relation(fields: [orderId], references: [id])
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())

  // Relations
  messages      Message[]

  @@unique([customerId, vendorId, orderId])
  @@index([customerId])
  @@index([vendorId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String?      @db.Text
  attachmentUrl  String?      @db.Text
  attachmentType String?      @db.VarChar(20)         // "image" | "file"
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

// ═══════════════════════════════════════════════════════
//  LOYALTY PROGRAM
// ═══════════════════════════════════════════════════════

// Singleton row — id is always "singleton"
model LoyaltySettings {
  id                   String   @id @default("singleton")
  isEnabled            Boolean  @default(true)
  // X% of order total converted to points  (e.g. 5 → 100 EGP order = 5 points)
  earnRatePercent      Decimal  @default(5.00) @db.Decimal(5, 2)
  // 1 point = X EGP when redeeming
  pointValue           Decimal  @default(0.50) @db.Decimal(10, 4)
  // User must have at least N points before they can redeem
  minRedemptionPoints  Int      @default(100)
  // Points discount cannot exceed X% of order total
  maxRedemptionPercent Decimal  @default(50.00) @db.Decimal(5, 2)
  // Points expire after N days from earning (0 = never expire)
  pointsExpireAfterDays Int     @default(365)
  updatedAt            DateTime @updatedAt

  // If empty → points redeemable on all categories
  redeemableCategories LoyaltyRedeemableCategory[]

  @@map("loyalty_settings")
}

// Allowed categories for points redemption
model LoyaltyRedeemableCategory {
  id         String          @id @default(uuid())
  settingsId String          @default("singleton")
  settings   LoyaltySettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([settingsId, categoryId])
  @@map("loyalty_redeemable_categories")
}

model LoyaltyAccount {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Int      @default(0)
  totalEarned   Int      @default(0)
  totalRedeemed Int      @default(0)
  updatedAt     DateTime @updatedAt

  transactions  LoyaltyTransaction[]

  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id           String                 @id @default(uuid())
  accountId    String
  account      LoyaltyAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type         LoyaltyTransactionType
  points       Int                    // positive = earned/adjusted; negative = redeemed/expired
  balanceAfter Int
  orderId      String?
  order        Order?                 @relation(fields: [orderId], references: [id])
  description  String?                @db.VarChar(255)
  expiresAt    DateTime?              // set on 'earned' transactions; null = never expires
  expiredAt    DateTime?              // set when this earned batch is actually expired
  createdAt    DateTime               @default(now())

  @@index([accountId])
  @@index([orderId])
  @@index([expiresAt])
  @@map("loyalty_transactions")
}

// ═══════════════════════════════════════════════════════
//  MEDIA LIBRARY
// ═══════════════════════════════════════════════════════

model MediaAsset {
  id           String         @id @default(uuid())
  url          String         @db.Text
  publicId     String         @db.VarChar(255)
  filename     String?        @db.VarChar(255)
  folder       String         @db.VarChar(100)   // e.g. "products", "vendors/logos"
  resourceType String         @default("image") @db.VarChar(20)
  uploadedById String
  uploadedBy   User           @relation(fields: [uploadedById], references: [id])
  vendorId     String?        // null = admin upload; set = vendor upload
  vendor       VendorProfile? @relation(fields: [vendorId], references: [id])
  createdAt    DateTime       @default(now())

  @@index([uploadedById])
  @@index([vendorId])
  @@index([folder])
  @@map("media_assets")
}

// ═══════════════════════════════════════════════════════
//  PLATFORM SETTINGS
// ═══════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════
//  ADMIN ACTIVITY LOGS
// ═══════════════════════════════════════════════════════

model AdminActivityLog {
  id          String   @id @default(uuid())
  adminId     String
  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action      String   @db.VarChar(100)   // e.g. "suspend_user", "approve_vendor"
  entityType  String?  @db.VarChar(50)    // e.g. "user", "vendor", "product"
  entityId    String?  @db.VarChar(100)
  entityLabel String?  @db.VarChar(255)   // human-readable name
  metadata    Json?                        // extra context { before, after, reason }
  ipAddress   String?  @db.VarChar(50)
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("admin_activity_logs")
}

// ═══════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════
//  CONTACT MESSAGES
// ═══════════════════════════════════════════════════════

model ContactMessage {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(255)
  subject   String   @db.VarChar(255)
  message   String   @db.Text
  status    String   @default("new") @db.VarChar(20) // new, read, replied
  repliedAt DateTime?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// ═══════════════════════════════════════════════════════
//  LEGAL PAGES (Terms & Privacy)
// ═══════════════════════════════════════════════════════

model LegalPage {
  id        String   @id @default(uuid())
  type      String   @db.VarChar(20)  // terms, privacy
  audience  String   @db.VarChar(20)  // vendor, customer
  title     Json     @default("{\"en\": \"\", \"ar\": \"\"}")
  content   Json     @default("{\"en\": \"\", \"ar\": \"\"}")
  slug      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([type, audience])
  @@map("legal_pages")
}

//  PLATFORM SETTINGS
// ═══════════════════════════════════════════════════════

model PlatformSettings {
  id              String   @id @default("singleton")
  platformName    Json     @default("{\"en\": \"Hagatna\", \"ar\": \"هاجتنا\"}")
  logo            String?  @db.Text
  favicon         String?  @db.Text
  currency        String   @default("EGP") @db.VarChar(10)
  taxRate         Float    @default(0)      // percentage e.g. 14 for 14%
  maintenanceMode Boolean  @default(false)
  supportEmail    String?  @db.VarChar(255)
  supportPhone    String?  @db.VarChar(50)
  termsUrl        String?  @db.Text
  privacyUrl      String?  @db.Text
  maxCartItems    Int      @default(50)
  updatedAt       DateTime @updatedAt

  @@map("platform_settings")
}

// ═══════════════════════════════════════════════════════
//  BANNERS (Homepage Carousel)
// ═══════════════════════════════════════════════════════

model Banner {
  id            String    @id @default(uuid())
  title         Json      @default("{\"en\": \"\", \"ar\": \"\"}")   // LocalizedString
  description   Json      @default("{\"en\": \"\", \"ar\": \"\"}")   // LocalizedString
  imageUrl      String    @db.VarChar(500)
  imagePublicId String    @db.VarChar(200)
  linkUrl       String?   @db.VarChar(500)
  order         Int       @default(0)
  isActive      Boolean   @default(true)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive, order])
  @@map("banners")
}
